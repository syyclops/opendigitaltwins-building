      "schema": "double",
      "unit": "gallon",
      "writable": true,
      "@id": "dtmi:com:syyclops:PotableWaterBillEvent:consumption;1"
    }
  ],
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1",
    "dtmi:dtdl:extension:annotation;1",
