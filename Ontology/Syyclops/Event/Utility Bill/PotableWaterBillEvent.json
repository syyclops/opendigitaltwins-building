{
  "@id": "dtmi:com:syyclops:PotableWaterBillEvent;1",
  "@type": "Interface",
  "displayName": {
    "en": "Potable Water Bill"
  },
  "description": {
    "en": "A utility bill for potable water service."
  },
  "extends": ["dtmi:com:syyclops:UtilityBillEvent;1"],
  "contents": [
    {
      "@type": "Property",
      "name": "meterData",
      "displayName": {
        "en": "Meter Data"
      },
      "description": {
        "en": "Per-meter readings on this bill."
      },
      "writable": true,
      "schema": {
        "@type": "Array",
        "elementSchema": {
          "@type": "Object",
          "fields": [
            {
              "name": "meterId",
              "displayName": {
                "en": "Meter Id"
              },
              "description": {
                "en": "The meter Id as provided by the utility account provider."
              },
              "schema": "string",
              "@id": "dtmi:com:syyclops:PotableWaterBillEvent:meterId;1"
            },
            {
              "name": "measurementType",
              "displayName": {
                "en": "Measurement Type"
              },
              "description": {
                "en": "Whether the reading is total consumption or peak demand during the billing period."
              },
              "schema": {
                "@type": "Enum",
                "valueSchema": "string",
                "enumValues": [
                  {
                    "name": "TotalConsumption",
                    "enumValue": "TotalConsumption",
                    "@id": "dtmi:com:syyclops:PotableWaterBillEvent:TotalConsumption;1"
                  },
                  {
                    "name": "PeakDemand",
                    "enumValue": "PeakDemand",
                    "@id": "dtmi:com:syyclops:PotableWaterBillEvent:PeakDemand;1"
                  }
                ],
                "@id": "dtmi:com:syyclops:PotableWaterBillEvent:ES1;1"
              },
              "@id": "dtmi:com:syyclops:PotableWaterBillEvent:measurementType;1"
            },
            {
              "name": "charge",
              "displayName": {
                "en": "Charge"
              },
              "description": {
                "en": "The individual charge for the usage as measured by the meter."
              },
              "schema": "dtmi:com:syyclops:UtilityBillEventCharges;1",
              "@id": "dtmi:com:syyclops:PotableWaterBillEvent:charge;1"
            },
            {
              "name": "usage",
              "displayName": {
                "en": "Usage"
              },
              "description": {
                "en": "The amount of usage as measured by the meter."
              },
              "schema": "dtmi:com:syyclops:PotableWaterBillEventUsage;1",
              "@id": "dtmi:com:syyclops:PotableWaterBillEvent:usage;1"
            }
          ],
          "@id": "dtmi:com:syyclops:PotableWaterBillEvent:OS1;1"
        },
        "@id": "dtmi:com:syyclops:PotableWaterBillEvent:AS1;1"
      },
      "@id": "dtmi:com:syyclops:PotableWaterBillEvent:meterData;1"
    }
  ],
  "schemas": [
    {
      "@id": "dtmi:com:syyclops:PotableWaterBillEventUsage;1",
      "@type": "Object",
      "displayName": {
        "en": "Potable Water Bill Event Usage"
      },
      "fields": [
        {
          "name": "amount",
          "displayName": {
            "en": "Amount"
          },
          "schema": "double",
          "@id": "dtmi:com:syyclops:PotableWaterBillEvent:SF1;1"
        },
        {
          "name": "unit",
          "displayName": {
            "en": "Unit"
          },
          "description": {
            "en": "Water unit reported by the utility."
          },
          "schema": {
            "@type": "Enum",
            "valueSchema": "string",
            "enumValues": [
              {
                "name": "gallon",
                "enumValue": "gallon",
                "@id": "dtmi:com:syyclops:PotableWaterBillEvent:Unitgallon;1"
              },
              {
                "name": "kgal",
                "enumValue": "kgal",
                "@id": "dtmi:com:syyclops:PotableWaterBillEvent:Unitkgal;1"
              },
              {
                "name": "CCF",
                "enumValue": "CCF",
                "@id": "dtmi:com:syyclops:PotableWaterBillEvent:UnitCCF;1"
              },
              {
                "name": "cubicMetre",
                "enumValue": "cubicMetre",
                "@id": "dtmi:com:syyclops:PotableWaterBillEvent:UnitcubicMetre;1"
              }
            ],
            "@id": "dtmi:com:syyclops:PotableWaterBillEvent:ES2;1"
          },
          "@id": "dtmi:com:syyclops:PotableWaterBillEvent:SF2;1"
        }
      ]
    }
  ],
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1",
    "dtmi:dtdl:extension:annotation;1",
    "dtmi:dtdl:extension:overriding;1"
  ]
}
