{
  "@id": "dtmi:com:syyclops:ElectricityBillEvent;1",
  "@type": "Interface",
  "displayName": {
    "en": "Electricity Bill"
  },
  "description": {
    "en": "A utility bill for electricity service."
  },
  "extends": ["dtmi:com:syyclops:UtilityBillEvent;1"],
  "contents": [
    {
      "@type": "Property",
      "name": "meterData",
      "displayName": {
        "en": "Meter Data"
      },
      "description": {
        "en": "Per-meter readings on this bill. Each entry represents one physical meter; fill only the measurement fields the meter actually reports."
      },
      "writable": true,
      "schema": {
        "@type": "Array",
        "elementSchema": {
          "@type": "Object",
          "fields": [
            {
              "name": "meterId",
              "displayName": {
                "en": "Meter Id"
              },
              "description": {
                "en": "The meter Id as provided by the utility account provider."
              },
              "schema": "string",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:meterId;1"
            },
            {
              "name": "charge",
              "displayName": {
                "en": "Charge"
              },
              "description": {
                "en": "The individual charge for this meter's reading."
              },
              "schema": "dtmi:com:syyclops:UtilityBillEventCharges;1",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:charge;1"
            },
            {
              "@type": ["Field", "Energy"],
              "name": "consumption",
              "displayName": {
                "en": "Consumption"
              },
              "description": {
                "en": "Total energy consumed during the billing period for this meter."
              },
              "schema": "double",
              "unit": "kilowattHour",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:consumption;1"
            },
            {
              "@type": ["Field", "Power"],
              "name": "peakDemand",
              "displayName": {
                "en": "Peak Demand"
              },
              "description": {
                "en": "Highest demand recorded during the billing period for this meter."
              },
              "schema": "double",
              "unit": "kilowatt",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:peakDemand;1"
            }
          ],
          "@id": "dtmi:com:syyclops:ElectricityBillEvent:OS1;1"
        },
        "@id": "dtmi:com:syyclops:ElectricityBillEvent:AS1;1"
      },
      "@id": "dtmi:com:syyclops:ElectricityBillEvent:meterData;1"
    }
  ],
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1",
    "dtmi:dtdl:extension:annotation;1",
    "dtmi:dtdl:extension:overriding;1"
  ]
}
