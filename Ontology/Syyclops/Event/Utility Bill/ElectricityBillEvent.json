{
  "@id": "dtmi:com:syyclops:ElectricityBillEvent;1",
  "@type": "Interface",
  "displayName": {
    "en": "Electricity Bill"
  },
  "description": {
    "en": "A utility bill for electricity service."
  },
  "extends": ["dtmi:com:syyclops:UtilityBillEvent;1"],
  "contents": [
    {
      "@type": "Property",
      "name": "meterData",
      "displayName": {
        "en": "Meter Data"
      },
      "description": {
        "en": "Per-meter readings on this bill. A single physical meter may yield multiple entries — e.g. one for total consumption (kWh) and one for peak demand (kW)."
      },
      "writable": true,
      "schema": {
        "@type": "Array",
        "elementSchema": {
          "@type": "Object",
          "fields": [
            {
              "name": "meterId",
              "displayName": {
                "en": "Meter Id"
              },
              "description": {
                "en": "The meter Id as provided by the utility account provider."
              },
              "schema": "string",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:meterId;1"
            },
            {
              "name": "measurementType",
              "displayName": {
                "en": "Measurement Type"
              },
              "description": {
                "en": "Whether the reading is total consumption or peak demand during the billing period."
              },
              "schema": {
                "@type": "Enum",
                "valueSchema": "string",
                "enumValues": [
                  {
                    "name": "TotalConsumption",
                    "enumValue": "TotalConsumption",
                    "@id": "dtmi:com:syyclops:ElectricityBillEvent:TotalConsumption;1"
                  },
                  {
                    "name": "PeakDemand",
                    "enumValue": "PeakDemand",
                    "@id": "dtmi:com:syyclops:ElectricityBillEvent:PeakDemand;1"
                  }
                ],
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:ES1;1"
              },
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:measurementType;1"
            },
            {
              "name": "charge",
              "displayName": {
                "en": "Charge"
              },
              "description": {
                "en": "The individual charge for the usage as measured by the meter."
              },
              "schema": "dtmi:com:syyclops:UtilityBillEventCharges;1",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:charge;1"
            },
            {
              "name": "usage",
              "displayName": {
                "en": "Usage"
              },
              "description": {
                "en": "The amount of usage as measured by the meter."
              },
              "schema": "dtmi:com:syyclops:ElectricityBillEventUsage;1",
              "@id": "dtmi:com:syyclops:ElectricityBillEvent:usage;1"
            }
          ],
          "@id": "dtmi:com:syyclops:ElectricityBillEvent:OS1;1"
        },
        "@id": "dtmi:com:syyclops:ElectricityBillEvent:AS1;1"
      },
      "@id": "dtmi:com:syyclops:ElectricityBillEvent:meterData;1"
    }
  ],
  "schemas": [
    {
      "@id": "dtmi:com:syyclops:ElectricityBillEventUsage;1",
      "@type": "Object",
      "displayName": {
        "en": "Electricity Bill Event Usage"
      },
      "fields": [
        {
          "name": "amount",
          "displayName": {
            "en": "Amount"
          },
          "schema": "double",
          "@id": "dtmi:com:syyclops:ElectricityBillEvent:SF1;1"
        },
        {
          "name": "unit",
          "displayName": {
            "en": "Unit"
          },
          "description": {
            "en": "Electrical unit. kilowattHour/megawattHour for consumption; kilowatt/megawatt for demand; kilovoltAmpereHour/kilovoltAmpere for apparent power."
          },
          "schema": {
            "@type": "Enum",
            "valueSchema": "string",
            "enumValues": [
              {
                "name": "kilowattHour",
                "enumValue": "kilowattHour",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:UnitkilowattHour;1"
              },
              {
                "name": "megawattHour",
                "enumValue": "megawattHour",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:UnitmegawattHour;1"
              },
              {
                "name": "kilowatt",
                "enumValue": "kilowatt",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:Unitkilowatt;1"
              },
              {
                "name": "megawatt",
                "enumValue": "megawatt",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:Unitmegawatt;1"
              },
              {
                "name": "kilovoltAmpereHour",
                "enumValue": "kilovoltAmpereHour",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:UnitkilovoltAmpereHour;1"
              },
              {
                "name": "kilovoltAmpere",
                "enumValue": "kilovoltAmpere",
                "@id": "dtmi:com:syyclops:ElectricityBillEvent:UnitkilovoltAmpere;1"
              }
            ],
            "@id": "dtmi:com:syyclops:ElectricityBillEvent:ES2;1"
          },
          "@id": "dtmi:com:syyclops:ElectricityBillEvent:SF2;1"
        }
      ]
    }
  ],
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1",
    "dtmi:dtdl:extension:annotation;1",
    "dtmi:dtdl:extension:overriding;1"
  ]
}
