{
  "@id": "dtmi:com:syyclops:NaturalGasBillEvent;1",
  "@type": "Interface",
  "displayName": {
    "en": "Natural Gas Bill"
  },
  "description": {
    "en": "A utility bill for natural gas service."
  },
  "extends": ["dtmi:com:syyclops:UtilityBillEvent;1"],
  "contents": [
    {
      "@type": "Property",
      "name": "meterData",
      "displayName": {
        "en": "Meter Data"
      },
      "description": {
        "en": "Per-meter readings on this bill. Volumetric readings (CCF/MCF/m³) should be converted to therms at ingestion using the utility's BTU factor."
      },
      "writable": true,
      "schema": {
        "@type": "Array",
        "elementSchema": {
          "@type": "Object",
          "fields": [
            {
              "name": "meterId",
              "displayName": {
                "en": "Meter Id"
              },
              "description": {
                "en": "The meter Id as provided by the utility account provider."
              },
              "schema": "string",
              "@id": "dtmi:com:syyclops:NaturalGasBillEvent:meterId;1"
            },
            {
              "name": "charge",
              "displayName": {
                "en": "Charge"
              },
              "description": {
                "en": "The individual charge for this meter's reading."
              },
              "schema": "dtmi:com:syyclops:UtilityBillEventCharges;1",
              "@id": "dtmi:com:syyclops:NaturalGasBillEvent:charge;1"
            },
            {
              "@type": ["Field", "Energy"],
              "name": "consumption",
              "displayName": {
                "en": "Consumption"
              },
              "description": {
                "en": "Total natural gas energy consumed during the billing period for this meter."
              },
              "schema": "double",
              "unit": "therm",
              "@id": "dtmi:com:syyclops:NaturalGasBillEvent:consumption;1"
            }
          ],
          "@id": "dtmi:com:syyclops:NaturalGasBillEvent:OS1;1"
        },
        "@id": "dtmi:com:syyclops:NaturalGasBillEvent:AS1;1"
      },
      "@id": "dtmi:com:syyclops:NaturalGasBillEvent:meterData;1"
    }
  ],
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1",
    "dtmi:dtdl:extension:annotation;1",
    "dtmi:dtdl:extension:overriding;1"
  ]
}
