                    "name": "critical",
                    "enumValue": 1,
                    "displayName": { "en": "Critical" },
                    "description": { "en": "Do not occupy. Supervisor notified immediately." },
                    "@id": "dtmi:com:syyclops:SpaceBoundaries:condition_critical;1"
                  },
                  {
                    "name": "poor",
                    "enumValue": 2,
                    "displayName": { "en": "Poor" },
                    "description": { "en": "Repair required before next occupancy." },
                    "@id": "dtmi:com:syyclops:SpaceBoundaries:condition_poor;1"
