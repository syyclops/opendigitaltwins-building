                  {
                    "name": "excellent",
                    "enumValue": 5,
                    "displayName": { "en": "Excellent" },
                    "description": { "en": "New or like-new. No action." },
                    "@id": "dtmi:com:syyclops:SpaceBoundaries:condition_excellent;1"
