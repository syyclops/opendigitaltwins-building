                  {
                    "name": "fair",
                    "enumValue": 3,
                    "displayName": { "en": "Fair" },
                    "description": { "en": "Schedule maintenance within 90 days." },
                    "@id": "dtmi:com:syyclops:SpaceBoundaries:condition_fair;1"
                  },
                  {
                    "name": "good",
                    "enumValue": 4,
                    "displayName": { "en": "Good" },
                    "description": { "en": "Minor wear. No action required." },
                    "@id": "dtmi:com:syyclops:SpaceBoundaries:condition_good;1"
