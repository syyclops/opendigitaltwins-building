      "displayName": {
        "en": "Walls Area Unit"
      },
      "annotates": "walls",
      "writable": true,
      "schema": "string",
      "@id": "dtmi:com:syyclops:SpaceBoundaries:wallsAreaUnit;1",
      "description": {
        "en": "Specifies the unit of measurement for the wall areas."
      }
    },
