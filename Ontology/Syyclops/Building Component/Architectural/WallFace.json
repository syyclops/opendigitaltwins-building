        "en": "Assessed condition of this wall face as it appears in its space, on a fixed 1-5 scale."
      },
      "schema": {
        "@type": "Enum",
        "@id": "dtmi:com:syyclops:WallFace:WallCondition;1",
        "valueSchema": "integer",
        "enumValues": [
          {
            "name": "critical",
            "enumValue": 1,
            "displayName": { "en": "Critical" },
            "description": { "en": "Do not occupy. Supervisor notified immediately." },
            "@id": "dtmi:com:syyclops:WallFace:condition_critical;1"
          },
          {
            "name": "poor",
            "enumValue": 2,
            "displayName": { "en": "Poor" },
            "description": { "en": "Repair required before next occupancy." },
            "@id": "dtmi:com:syyclops:WallFace:condition_poor;1"
          },
          {
            "name": "fair",
            "enumValue": 3,
            "displayName": { "en": "Fair" },
            "description": { "en": "Schedule maintenance within 90 days." },
            "@id": "dtmi:com:syyclops:WallFace:condition_fair;1"
          },
          {
            "name": "good",
            "enumValue": 4,
            "displayName": { "en": "Good" },
            "description": { "en": "Minor wear. No action required." },
            "@id": "dtmi:com:syyclops:WallFace:condition_good;1"
          },
          {
            "name": "excellent",
            "enumValue": 5,
            "displayName": { "en": "Excellent" },
            "description": { "en": "New or like-new. No action." },
            "@id": "dtmi:com:syyclops:WallFace:condition_excellent;1"
          }
