  "@type": "Interface",
  "displayName": {
    "en": "Wall Face"
  },
  "extends": [
    "dtmi:com:syyclops:ArchitecturalBuildingComponent;1"
  ],
  "contents": [
    {
      "@type": "Relationship",
      "name": "faceOf",
      "displayName": {
        "en": "face of"
      },
      "target": "dtmi:com:syyclops:Wall;1",
      "maxMultiplicity": 1,
      "@id": "dtmi:com:syyclops:WallFace:faceOf;1",
      "description": {
        "en": "The wall this face belongs to. A wall shared between two spaces has one Wall Face per side, each pointing at the same Wall twin."
      }
    },
    {
      "@type": "Property",
      "name": "area",
      "displayName": {
        "en": "Area"
      },
      "writable": true,
      "schema": "double",
