{
  "@id": "dtmi:com:syyclops:Space;1",
  "@type": "Interface",
  "displayName": {
    "en": "Space"
  },
  "description": {
    "en": "A contiguous part of the physical world that has a 3D spatial extent and that contains or can contain sub-spaces. E.g., a Region can contain many pieces of Land, which in turn can contain many Buildings."
  },
  "extends": [],
  "contents": [
    {
      "@type": "Property",
      "name": "wallDetails",
      "displayName": {
        "en": "Wall Details"
      },
      "writable": true,
      "schema": {
        "@type": "Array",
        "@id": "dtmi:com:syyclops:Space:wallDetailsArray;1",
        "elementSchema": {
          "@type": "Object",
          "@id": "dtmi:com:syyclops:Space:wallDetailsObject;1",
          "fields": [
            {
              "name": "geometryExternalID",
              "displayName": {
                "en": "Geometry External ID"
              },
              "schema": "string",
              "@id": "dtmi:com:syyclops:Space:wdGeometryExternalID;1",
              "description": {
                "en": "Join key to the bounding wall in the boundaries.walls[] geometry (Revit GUID). Ties this room-facing wall detail to the shared Wall twin."
              }
            },
            {
              "name": "condition",
              "displayName": {
                "en": "Condition"
              },
              "@id": "dtmi:com:syyclops:Space:wdCondition;1",
              "description": {
                "en": "Assessed condition of this wall as it appears in this room, on a fixed 1-5 scale."
              },
              "schema": {
                "@type": "Enum",
                "@id": "dtmi:com:syyclops:Space:WallCondition;1",
                "valueSchema": "integer",
                "enumValues": [
                  {
                    "name": "critical",
                    "enumValue": 1,
                    "displayName": { "en": "Critical" },
                    "description": { "en": "Do not occupy. Supervisor notified immediately." },
                    "@id": "dtmi:com:syyclops:Space:condition_critical;1"
                  },
                  {
                    "name": "poor",
                    "enumValue": 2,
                    "displayName": { "en": "Poor" },
                    "description": { "en": "Repair required before next occupancy." },
                    "@id": "dtmi:com:syyclops:Space:condition_poor;1"
                  },
                  {
                    "name": "fair",
                    "enumValue": 3,
                    "displayName": { "en": "Fair" },
                    "description": { "en": "Schedule maintenance within 90 days." },
                    "@id": "dtmi:com:syyclops:Space:condition_fair;1"
                  },
                  {
                    "name": "good",
                    "enumValue": 4,
                    "displayName": { "en": "Good" },
                    "description": { "en": "Minor wear. No action required." },
                    "@id": "dtmi:com:syyclops:Space:condition_good;1"
                  },
                  {
                    "name": "excellent",
                    "enumValue": 5,
                    "displayName": { "en": "Excellent" },
                    "description": { "en": "New or like-new. No action." },
                    "@id": "dtmi:com:syyclops:Space:condition_excellent;1"
                  }
                ]
              }
            },
            {
