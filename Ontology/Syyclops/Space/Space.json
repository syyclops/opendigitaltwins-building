      "@id": "dtmi:com:syyclops:Space:wallDetails;1",
      "description": {
        "en": "Per-room descriptive detail for each bounding wall (condition, construction type, finish, base). Keyed to boundaries.walls[] by geometryExternalID. Owned by Syyclops/manual entry and kept separate from the pipeline-populated walls[] geometry, so the same shared wall can carry different condition/finish in each room and BIM geometry re-imports never overwrite user-entered data."
      }
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "Indicates that a Space or Asset is served by some Sensor/Actuator or other Asset. For example: an entrance room might be served by (e.g., covered by) some camera equipment, or a conference room served by a CO2 sensor. Note that Assets can also service one another, e.g., an air-treatment Asset might serve an air diffuser Asset. Inverse of: serves"
      },
      "displayName": {
        "en": "served by"
      },
      "name": "servedBy",
      "properties": [
        {
          "@type": "Property",
          "name": "connectorOnboardingStatus",
          "displayName": {
            "en": "Connector Onboarding Status"
          },
          "description": {
            "en": "The status of onboarding the twins and relationships for a connector that has been installed. Used to filter out data quality alerts for connectors that are not Complete."
          },
          "writable": true,
          "schema": "dtmi:com:syyclops:SpaceServedByConnectorOnboardingStatus;1"
        }
      ],
      "@id": "dtmi:com:syyclops:Space:servedBy;1"
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "The coverage or impact area of a given Asset or Sensor/Actuator. For example: an air-treatment unit might serve several Rooms or a full Building. Note that Assets can also service one another, e.g., an air-treatment Asset might serve an air diffuser Asset. Inverse of: servedBy"
      },
      "displayName": {
        "en": "serves"
      },
      "name": "serves",
      "@id": "dtmi:com:syyclops:Space:serves;1"
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "Indicates that two spaces are adjacent to each other."
      },
      "displayName": {
        "en": "is adjacent to"
      },
      "name": "isAdjacentTo",
      "target": "dtmi:com:syyclops:Space;1",
      "@id": "dtmi:com:syyclops:Space:isAdjacentTo;1"
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "The walls (or other building elements) that physically delimit this space. A shared wall bounds each of the spaces it separates."
      },
      "displayName": {
        "en": "bounded by"
      },
      "name": "boundedBy",
      "target": "dtmi:com:syyclops:Wall;1",
      "@id": "dtmi:com:syyclops:Space:boundedBy;1"
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "Property that defines the legal owner(s) of a given entity. Inverse of: owns"
      },
      "displayName": {
