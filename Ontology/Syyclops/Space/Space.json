                  { "name": "glassCurtainWall", "enumValue": "glass_curtain_wall", "displayName": { "en": "Glass curtain wall" }, "@id": "dtmi:com:syyclops:Space:construction_glassCurtainWall;1" },
                  { "name": "lgs", "enumValue": "lgs", "displayName": { "en": "Light-gauge steel (LGS)" }, "@id": "dtmi:com:syyclops:Space:construction_lgs;1" },
                  { "name": "aac", "enumValue": "aac", "displayName": { "en": "Autoclaved aerated concrete (AAC)" }, "@id": "dtmi:com:syyclops:Space:construction_aac;1" },
